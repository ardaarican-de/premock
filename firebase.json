{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "ignore": [
      "node_modules",
      ".git",
      "*.local"
    ]
  },
  "hosting": {
    "public": "public-share",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/s/**",
        "function": {
          "functionId": "shareOG",
          "region": "us-central1"
        }
      }
    ],
    "redirects": [
      {
        "source": "/",
        "destination": "https://premock.co/",
        "type": 302
      }
    ]
  }
}
